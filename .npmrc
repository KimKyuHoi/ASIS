# pnpm 설정.
# Electron 의 native modules (electron, electron-builder, electron-vite 등) 가
# 평탄한 node_modules 를 가정하고 동작하므로 pnpm 의 기본 isolated 구조 대신
# 호환성 우선의 hoisted 구조를 사용한다.
#
# 트레이드오프
#   + Electron / electron-builder 동작 안정 (npm 과 거의 동등)
#   + ESLint / Prettier / Konva 등이 평탄 트리 가정해도 OK
#   - pnpm 의 phantom dependency 차단 효과는 약화
node-linker=hoisted

# 신규 의존성을 추가할 때 lockfile 갱신 강제
strict-peer-dependencies=false
